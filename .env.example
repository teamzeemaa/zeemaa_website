# ─────────────────────────────────────────────────────────────
# Zeemaa – Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────────

# ── Google Analytics 4 ──────────────────────────────────────
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Google Ads ───────────────────────────────────────────────
# Get from: ads.google.com → Tools → Conversions → Tag details
NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXX

# Conversion action IDs (one per form type)
# Format: AW-{account_id}/{conversion_label}
# Get from: Google Ads → Goals → Conversions → click the conversion → Tag setup
NEXT_PUBLIC_GADS_CONV_DEMO=AW-XXXXXXXXX/XXXXXXXXX
NEXT_PUBLIC_GADS_CONV_CONTACT=AW-XXXXXXXXX/XXXXXXXXX

# ── Meta Pixel (optional — leave blank to disable) ───────────
NEXT_PUBLIC_META_PIXEL_ID=

# ── SMTP (for form emails to hello@zeemaa.com) ───────────────
# Using Gmail: enable 2FA → create App Password → use below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@zeemaa.com
SMTP_PASS=your-app-password-here

# ── Admin console ────────────────────────────────────────────
# Change this to a strong password before launch
ADMIN_PASSWORD=change-me-before-launch
# Random 32-char string — used to sign the session cookie
SESSION_SECRET=zeemaa-session-secret-change-this-2025
